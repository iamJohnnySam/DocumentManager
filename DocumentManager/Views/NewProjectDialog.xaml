<Window x:Class="DocumentManager.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Project" Height="340" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Create New LaTeX Project"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Project Code:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProjectCodeBox" Margin="0,4" Padding="4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Title:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TitleBox" Margin="0,4" Padding="4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Author:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="AuthorBox" Margin="0,4" Padding="4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Template:" VerticalAlignment="Center" Margin="0,4"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="TemplateComboBox" Margin="0,4" Padding="4"/>

        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Foreground="Gray" FontSize="11"
                   TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="The project will be created inside the shared main files folder."/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Create" Width="90" IsDefault="True" Click="Create_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="90" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
