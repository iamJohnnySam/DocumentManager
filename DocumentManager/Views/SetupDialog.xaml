<Window x:Class="DocumentManager.Views.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LaTeX Document Manager — First-Time Setup" Height="280" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to LaTeX Document Manager" FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,16" Foreground="Gray">
            Choose a folder that will store all your shared LaTeX sections, common images, and projects.
            This folder is shared across every project you create.
        </TextBlock>

        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Main Files Folder:" VerticalAlignment="Center" Width="120"/>
            <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Margin="8,0,0,0"
                    Click="Browse_Click"/>
            <TextBox x:Name="RootPathBox" Padding="4" VerticalContentAlignment="Center"/>
        </DockPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Continue" Width="100" IsDefault="True" Click="Continue_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Exit" Width="80" IsCancel="True" Click="Exit_Click"/>
        </StackPanel>
    </Grid>
</Window>
