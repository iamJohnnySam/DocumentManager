<Window x:Class="DocumentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentManager"
        xmlns:conv="clr-namespace:DocumentManager.Converters"
        xmlns:models="clr-namespace:DocumentManager.Models"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToBrushConverter x:Key="BoolToBrush"/>
        <conv:NodeTypeToIconConverter x:Key="NodeToIcon"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TOP MENU BAR ===== -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _All" Command="{Binding SaveAllCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Add _Section..." Command="{Binding AddSectionCommand}"/>
                <MenuItem Header="Browse Available _Files..." Command="{Binding BrowseAvailableFilesCommand}"/>
                <Separator/>
                <MenuItem Header="Save _Snippet..." Command="{Binding SaveSnippetCommand}"/>
                <MenuItem Header="Save as _Template..." Command="{Binding SaveAsTemplateCommand}"/>
            </MenuItem>
            <MenuItem Header="_Build">
                <MenuItem Header="_Compile" Command="{Binding CompileCommand}" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Compiler:"/>
                <MenuItem Header="pdflatex" IsCheckable="True"
                          IsChecked="{Binding SelectedCompiler, Converter={x:Static local:StringMatchConverter.Instance}, ConverterParameter=pdflatex}"
                          IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Refresh Tree" Command="{Binding RefreshTreeCommand}"/>
                <MenuItem Header="Check _Notifications" Command="{Binding CheckNotificationsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About LDMS" Command="{Binding ShowAboutCommand}"/>
                <MenuItem Header="_Source Code (GitHub)" Command="{Binding OpenGitHubCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="240" MinWidth="160"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT PANEL: Project Tree ===== -->
            <DockPanel Grid.Column="0" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="Project Explorer" FontWeight="Bold"
                           Margin="4,4,4,8" FontSize="13"/>
                <TreeView ItemsSource="{Binding ProjectTree.Nodes}"
                          MouseDoubleClick="TreeView_MouseDoubleClick"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:ProjectTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal"
                                        Background="{Binding HasNewerRevision, Converter={StaticResource BoolToBrush}}">
                                <TextBlock Text="{Binding NodeType, Converter={StaticResource NodeToIcon}}"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text=" ★" Foreground="OrangeRed"
                                           Visibility="{Binding HasNewerRevision, Converter={StaticResource BoolToVis}}"
                                           ToolTip="Newer revision available"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="LightGray"/>

            <!-- ===== CENTER: Tabbed Editor + PDF Preview ===== -->
            <Grid Grid.Column="2" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Compiler Selection Bar -->
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="Compiler:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding AvailableCompilers}"
                              SelectedItem="{Binding SelectedCompiler}"
                              Width="120" Margin="0,0,8,0"/>
                    <Button Content="▶ Compile" Command="{Binding CompileCommand}"
                            Padding="8,2" Margin="0,0,8,0"/>
                    <Button Content="+ Section" Command="{Binding AddSectionCommand}"
                            Padding="8,2" Margin="0,0,8,0"/>
                    <Button Content="📂 Manage Sections" Command="{Binding BrowseAvailableFilesCommand}"
                            Padding="8,2" Margin="0,0,8,0"/>
                    <ToggleButton x:Name="PdfToggleButton" Content="📄 PDF Preview"
                                  Padding="8,2" Margin="0,0,8,0"
                                  IsChecked="{Binding IsPdfPreviewVisible, Mode=OneWay}"
                                  Click="PdfToggle_Click"/>
                    <!-- Notifications -->
                    <ItemsControl ItemsSource="{Binding Notifications}" DockPanel.Dock="Right"
                                  HorizontalAlignment="Right" Margin="8,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="OrangeRed" FontSize="11"
                                           Margin="4,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <!-- Editor + PDF side by side -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition x:Name="PdfPreviewColumn" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tab Editor -->
                    <TabControl Grid.Column="0"
                                ItemsSource="{Binding Editor.OpenTabs}"
                                SelectedItem="{Binding Editor.SelectedTab}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayTitle}" Margin="0,0,6,0"/>
                                    <Button Content="✕" FontSize="10" Padding="2,0"
                                            Command="{Binding DataContext.Editor.CloseTabCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Line Numbers -->
                                    <TextBox Grid.Column="0" Text="{Binding LineNumbers, Mode=OneWay}"
                                             IsReadOnly="True" Background="#F0F0F0" Foreground="Gray"
                                             FontFamily="Consolas" FontSize="13"
                                             BorderThickness="0,0,1,0" BorderBrush="LightGray"
                                             TextAlignment="Right" Padding="4,4,8,4"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Hidden"
                                             IsTabStop="False"
                                             ScrollViewer.CanContentScroll="True"
                                             x:Name="LineNumberBox"/>
                                    <!-- Editor TextBox -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="13"
                                             Padding="4" BorderThickness="0"
                                             SpellCheck.IsEnabled="False"
                                             GotFocus="EditorTextBox_GotFocus"/>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- PDF Splitter (visible only when PDF panel is open) -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="LightGray"
                                  x:Name="PdfSplitter" Visibility="Collapsed"/>

                    <!-- PDF Preview Panel -->
                    <DockPanel Grid.Column="2" x:Name="PdfPreviewPanel" Visibility="Collapsed">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="PDF Preview" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center" Margin="4,0"/>
                            <Button Content="⟳" ToolTip="Reload PDF" Padding="6,2"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Click="ReloadPdf_Click"/>
                        </DockPanel>
                        <wv2:WebView2 x:Name="PdfWebView"/>
                    </DockPanel>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="LightGray"/>

            <!-- ===== RIGHT PANEL: Images & Snippets ===== -->
            <DockPanel Grid.Column="4" Margin="4">
                <TabControl>
                    <!-- Snippets Tab -->
                    <TabItem Header="Snippets">
                        <DockPanel>
                            <Button DockPanel.Dock="Bottom" Content="Insert Snippet"
                                    Command="{Binding InsertSnippetCommand}" Margin="4" Padding="4,2"/>
                            <ListBox ItemsSource="{Binding Snippets}"
                                     SelectedItem="{Binding SelectedSnippet}"
                                     Margin="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Content}" FontSize="10"
                                                       Foreground="Gray" MaxHeight="40"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Images Tab -->
                    <TabItem Header="Images">
                        <DockPanel>
                            <TextBox DockPanel.Dock="Top"
                                     Text="{Binding ImageGallery.SearchFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="4" Padding="4"/>
                            <StackPanel DockPanel.Dock="Bottom" Margin="4,2">
                                <Button Content="Insert Image" Margin="0,0,0,2"
                                        Command="{Binding InsertImageCommand}" Padding="4,2"/>
                                <Button Content="+ Import to Project" Margin="0,0,0,2"
                                        Command="{Binding ImportProjectImageCommand}" Padding="4,2"/>
                                <Button Content="+ Import to Common" Margin="0,0,0,0"
                                        Command="{Binding ImportCommonImageCommand}" Padding="4,2"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding ImageGallery.FilteredImages}"
                                     SelectedItem="{Binding ImageGallery.SelectedImage}"
                                     Margin="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding FileName}" FontSize="11"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Category}" FontSize="9"
                                                       Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- Search Tab -->
                    <TabItem Header="Search">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="4">
                                <Button DockPanel.Dock="Right" Content="🔍" Padding="6,2"
                                        Command="{Binding SearchCommand}"/>
                                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="4"/>
                            </DockPanel>
                            <ListBox ItemsSource="{Binding SearchResults}" Margin="4"
                                     MouseDoubleClick="SearchResult_DoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock FontSize="11">
                                                <Run Text="{Binding FileName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" : "/>
                                                <Run Text="{Binding LineNumber, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LineContent}" FontSize="10"
                                                       Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Grid>

        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Background="LightGray"/>

        <!-- ===== BOTTOM PANEL: Output / Logs ===== -->
        <DockPanel Grid.Row="3" Margin="4">
            <TextBlock DockPanel.Dock="Top" Text="Output" FontWeight="Bold" Margin="4,0,4,4"/>
            <TextBox x:Name="OutputTextBox" Text="{Binding OutputLog, Mode=OneWay}" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="11"
                     Background="#1E1E1E" Foreground="#DCDCDC" Padding="4"
                     TextChanged="OutputTextBox_TextChanged"/>
        </DockPanel>

        <!-- ===== STATUS BAR ===== -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
